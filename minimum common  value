class Solution {
public:
    int getCommon(vector<int>& nums1, vector<int>& nums2) {
    int mincommon =  INT_MAX;
  unordered_set<int> s(nums1.begin(), nums1.end());
    

       for(int x : nums2){
        if(s.find(x) != s.end()){

            if(x < mincommon){
                mincommon = x;
            }
        }
       }

       if ( mincommon == INT_MAX){
      mincommon = -1 ;
       }
            
        
        return mincommon ;
    }
};

class Solution {
public:
    bool checkOnesSegment(string s) {

        bool ans = true ;

        for(int i=0; i<s.size(); i++){
            if(i==0){
                continue ;}
          if(s[i] == '1' && s[i-1] == '0'){
                return false;
            }
        }
        return ans;
    }
};
